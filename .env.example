# Copy this file to .env and fill in real values before running docker compose.
# NEVER commit the real .env file to version control.

# --- Database ---
DB_NAME=ia_marks_db
DB_USER=ia_marks_user
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_RANDOM_PASSWORD

# --- JWT ---
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=604800000

# --- CORS ---
# Set to your real domain(s) in production, comma-separated, no trailing slash
CORS_ALLOWED_ORIGINS=http://localhost

# --- First admin account (created automatically on first backend startup) ---
ADMIN_EMAIL=admin@university.edu
ADMIN_PASSWORD=CHANGE_ME_STRONG_TEMP_PASSWORD
